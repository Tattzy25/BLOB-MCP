{
  "name": "vercel-blob-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Vercel Blob storage — direct REST (no @vercel/blob SDK), streamable HTTP transport, Railway-ready.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
