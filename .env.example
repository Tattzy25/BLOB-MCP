# ---- REQUIRED ----
# All three must be set. The server refuses to start if any are missing.

# Vercel Blob read/write token.
# Dashboard -> Storage -> your blob store -> .env.local tab.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bearer token required on every POST /mcp request.
# Pick a long random string. Rotate it if it ever leaks.
MCP_SERVER_TOKEN=your-long-random-string-here

# TCP port to bind. Railway injects this automatically in production.
PORT=3000
